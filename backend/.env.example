# 腾讯混元 API 密钥（从腾讯云控制台获取）
HUNYUAN_SECRET_ID=your_secret_id_here
HUNYUAN_SECRET_KEY=your_secret_key_here
# 模型选择: hunyuan-lite(免费) / hunyuan-standard / hunyuan-pro
HUNYUAN_MODEL=hunyuan-lite

# 每日刷新时间
REFRESH_HOUR=9
REFRESH_MINUTE=0

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=real-estate-stock-agent-secret-key-2025

# 默认管理员账户（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 同花顺iFinD API（可选，提供更全面的数据源）
IFIND_REFRESH_TOKEN=your_refresh_token_here
IFIND_ACCESS_TOKEN=your_access_token_here
