# LKEAP OpenAI 兼容接口 API Key（三模型共用）
# 在 https://hunyuan.cloud.tencent.com/#/app/apiKeyManage 创建
LKEAP_API_KEY=your_lkeap_api_key_here

# ── DeepSeek V3.2 配置（LKEAP OpenAI 兼容接口）──
DEEPSEEK_MODEL=deepseek-v3.2
DEEPSEEK_ENABLED=true

# ── GLM-5 配置（LKEAP OpenAI 兼容接口）──
GLM_MODEL=glm-5
GLM_ENABLED=true

# ── Kimi K2.5 配置（LKEAP OpenAI 兼容接口）──
KIMI_MODEL=kimi-k2.5
KIMI_ENABLED=true

# 三模型融合权重（之和应为1.0）
DEEPSEEK_WEIGHT=0.4
GLM_WEIGHT=0.3
KIMI_WEIGHT=0.3

# 每日刷新时间（默认早上8点）
REFRESH_HOUR=8
REFRESH_MINUTE=0

# JWT 密钥（生产环境请修改为随机字符串）
JWT_SECRET=real-estate-stock-agent-secret-key-2025

# 默认管理员账户（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 同花顺iFinD API（可选，提供更全面的数据源）
IFIND_REFRESH_TOKEN=your_refresh_token_here
IFIND_ACCESS_TOKEN=your_access_token_here
